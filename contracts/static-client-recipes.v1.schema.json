{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "static-client-recipes.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "environment", "recipes"],
  "properties": {
    "schemaVersion": { "const": "registry.static-client-recipes.v1" },
    "environment": {
      "type": "string",
      "enum": ["stillness", "utopia", "unknown"]
    },
    "clientBuild": { "type": "string" },
    "patchLabel": { "type": "string" },
    "resources": {
      "type": "array",
      "items": { "$ref": "source-artefact.v1.schema.json" }
    },
    "recipes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/recipe" }
    }
  },
  "$defs": {
    "recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recipeId", "name", "outputTypeId", "outputQuantity", "inputs"],
      "properties": {
        "recipeId": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "outputTypeId": { "type": "integer", "minimum": 1 },
        "outputQuantity": { "type": "integer", "minimum": 1 },
        "blueprintTypeId": { "type": "integer", "minimum": 1 },
        "facilityTypeId": { "type": "integer", "minimum": 1 },
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["typeId", "quantity"],
            "properties": {
              "typeId": { "type": "integer", "minimum": 1 },
              "quantity": { "type": "integer", "minimum": 1 }
            }
          }
        },
        "sourceContext": { "type": "string" }
      }
    }
  }
}
