{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tribe-identities.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "environment", "source", "tribes"],
  "properties": {
    "schemaVersion": { "const": "registry.tribe-identities.v1" },
    "environment": {
      "type": "string",
      "enum": ["stillness", "utopia", "unknown"]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "confidence", "title", "locator", "checkedAt", "reviewStatus"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "onchain",
            "sui_event",
            "sui_object",
            "world_api",
            "datahub",
            "static_client_data",
            "reverse_engineered",
            "observed_gameplay",
            "community_report",
            "manual_inference"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": ["verified", "probable", "reported", "stale", "unknown"]
        },
        "title": { "type": "string", "minLength": 1 },
        "locator": { "type": "string", "minLength": 1 },
        "url": { "type": "string" },
        "checkedAt": { "type": "string", "format": "date-time" },
        "reviewStatus": {
          "type": "string",
          "enum": ["reviewed", "published"]
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "tribes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/tribeIdentity" }
    }
  },
  "$defs": {
    "tribeIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tribeId", "name", "sourceContext"],
      "properties": {
        "tribeId": {
          "type": "string",
          "pattern": "^[1-9][0-9]*$",
          "minLength": 1
        },
        "name": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "aliases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "confidence": {
          "type": "string",
          "enum": ["verified", "probable", "reported", "stale", "unknown"]
        },
        "sourceContext": { "type": "string", "minLength": 1 },
        "cycle": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
