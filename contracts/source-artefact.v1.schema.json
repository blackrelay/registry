{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "source-artefact.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "sourceId",
    "sourceKind",
    "kind",
    "artefactKind",
    "environment",
    "pathOrUri",
    "sha256",
    "sizeBytes",
    "contentType",
    "extractedAt",
    "importerName",
    "importerVersion",
    "reviewStatus"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "sourceId": { "type": "string", "minLength": 1 },
    "sourceKind": { "$ref": "import-envelope.v1.schema.json#/$defs/sourceKind" },
    "kind": { "type": "string", "minLength": 1 },
    "artefactKind": { "type": "string", "minLength": 1 },
    "environment": { "$ref": "import-envelope.v1.schema.json#/$defs/environment" },
    "pathOrUri": { "type": "string", "minLength": 1 },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "sizeBytes": { "type": "integer", "minimum": 0 },
    "rowCount": { "type": "integer", "minimum": 0 },
    "contentType": { "type": "string", "minLength": 1 },
    "extractedAt": { "type": "string", "format": "date-time" },
    "importerName": { "type": "string", "minLength": 1 },
    "importerVersion": { "type": "string", "minLength": 1 },
    "clientBuild": { "type": "string" },
    "patchLabel": { "type": "string" },
    "cycle": { "type": "integer", "minimum": 1 },
    "reviewStatus": { "$ref": "import-envelope.v1.schema.json#/$defs/reviewStatus" },
    "supersededByArtefactId": { "type": "string" },
    "notes": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
