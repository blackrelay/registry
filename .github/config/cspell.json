{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en-GB",
  "useGitignore": true,
  "ignorePaths": [
    ".runs/**",
    "artefacts/**",
    "contracts/**",
    "exports/**",
    "go.mod",
    "go.sum",
    "migrations/**",
    "openapi/**",
    "testdata/**",
    "tmp/**"
  ],
  "ignoreRegExpList": [
    "/```[\\s\\S]*?```/g",
    "/~~~[\\s\\S]*?~~~/g",
    "/`[^`]+`/g",
    "/https?:\\/\\/[^\\s)]+/g",
    "/actions\\/upload-artifact@[A-Fa-f0-9]+/g",
    "/[A-Fa-f0-9]{16,}/g",
    "/0x[A-Fa-f0-9]+/g",
    "/[A-Z]:\\\\[^\\s)]+/g"
  ],
